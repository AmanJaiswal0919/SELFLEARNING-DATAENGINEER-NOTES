SELECT user.id AS userid,u.firstname,u.lastname,
customer.id AS customerid,c.customername,COUNT(*) AS contactcount
FROM Contact ct
INNER JOIN user u
ON ct.UserAccountid=u.id
INNER JOIN Customer c
ON ct.Customerid=c.id
GROUP BY u.id,u.firstname,u.lastname,c.id,c.customername
HAVING COUNT(*)>1
ORDER BY u.id ASC;

